# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/healthcare_dev"
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/healthcare_test"

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-with-32+-char-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-32+-char-random-string"
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
SLOT_HOLD_MINUTES=5

# ── Mock mode ────────────────────────────────────────────────────────────
# Runs the whole app end-to-end with zero paid API keys: AI falls back to a
# safe static summary, email logs to the console instead of sending, and
# calendar sync is skipped silently. Flip each to "false" only once you've
# filled in the matching real credentials below.
USE_MOCK_LLM=true
USE_MOCK_EMAIL=true
USE_MOCK_CALENDAR=true

# ── OpenAI (only used once USE_MOCK_LLM=false) ────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ── Email / SMTP (only used once USE_MOCK_EMAIL=false) ────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Harbor Clinic <no-reply@clinic.example>"

# ── Google Calendar OAuth2 (only used once USE_MOCK_CALENDAR=false) ──────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/oauth/callback"

# ── Cron ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 24 — sent as "Authorization: Bearer <value>"
# by whatever scheduler calls /api/cron/*
CRON_SECRET="replace-with-a-long-random-string"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
